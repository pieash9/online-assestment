            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Backend API Round 1\",\n  \"totalCandidates\": 10,\n  \"totalSlots\": 2,\n  \"questionSets\": 1,\n  \"questionType\": \"Mixed\",\n  \"startTime\": \"2026-04-10T09:00:00.000Z\",\n  \"endTime\": \"2026-04-10T12:00:00.000Z\",\n  \"durationMinutes\": 60,\n  \"negativeMarking\": 0.25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employer/exams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "employer",
                "exams"
