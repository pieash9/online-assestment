    {
      "key": "textQuestionId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        },
        "description": "Check that the API server is running."
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Employer Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) {",
                  "  pm.collectionVariables.set('employerToken', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employer@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Seeded employer credentials from prisma/seed.ts"
          }
        },
        {
          "name": "Candidate Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) {",
                  "  pm.collectionVariables.set('candidateToken', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"candidate1@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Seeded candidate credentials from prisma/seed.ts"
          }
        }
      ]
    },
    {
      "name": "Employer",
      "item": [
        {
          "name": "List Exams",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/employer/exams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "employer",
                "exams"
              ]
            },
            "description": "Use the returned exam id to fill {{examId}}."
          }
        },
        {
          "name": "Create Exam",
          "request": {
            "method": "POST",
            "header": [
              {
