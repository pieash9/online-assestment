{
  "info": {
    "_postman_id": "0f744de3-4c31-466f-97bd-2c04f18e9a20",
    "name": "Online Assessment Platform API",
    "description": "Postman collection for the seeded Online Assessment Platform backend. Seeded credentials come from prisma/seed.ts.",
